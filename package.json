{
  "name": "@llamaindex/liteparse-server",
  "module": "src/index.ts",
  "type": "module",
  "author": {
    "name": "Clelia Astra Bertelli",
    "email": "clelia@runllama.ai"
  },
  "description": "API server running LiteParse to parse and screenshot files, wrote in Express.js",
  "keywords": [
    "liteparse",
    "document-parsing",
    "ocr",
    "server",
    "express-js"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@llamaindex/liteparse": "^1.5.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "async-mutex": "^0.5.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "rate-limiter-flexible": "^11.0.1",
    "tslog": "^4.10.2"
  },
  "scripts": {
    "start:bun": "bun run --preload ./src/instrumentation.ts src/index.ts",
    "start:node": "node --import ./src/instrumentation.ts src/index.ts"
  }
}
