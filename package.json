{
  "name": "@llamaindex/liteparse-server",
  "module": "src/index.ts",
  "type": "module",
  "author": {
    "name": "Clelia Astra Bertelli",
    "email": "clelia@runllama.ai"
  },
  "description": "API server running LiteParse to parse and screenshot files, wrote in Express.js",
  "keywords": [
    "liteparse",
    "document-parsing",
    "ocr",
    "server",
    "express-js"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-prometheus": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.216.0",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "async-mutex": "^0.5.0",
    "ioredis": "^5.10.1",
    "rate-limiter-flexible": "^11.0.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@llamaindex/liteparse": "^2.4.0",
    "@opentelemetry/api": "^1.9.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "tslog": "^4.10.2"
  },
  "scripts": {
    "start:bun": "bun run --preload ./src/instrumentation.ts src/index.ts",
    "start:node": "node --import ./src/instrumentation.ts src/index.ts",
    "start-slim:bun": "bun run src/run.ts",
    "start-slim:node": "node src/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/** && eslint __tests__/**",
    "prettier": "prettier --write .",
    "prettier:check": "prettier ."
  },
  "workspaces": [
    "packages/*"
  ]
}
